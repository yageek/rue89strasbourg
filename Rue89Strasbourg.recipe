#!/usr/bin/env python
# vim:fileencoding=utf-8
from urllib.parse import parse_qs, urlparse
import mechanize
from calibre.ebooks.BeautifulSoup import BeautifulSoup
from calibre.web.feeds.news import BasicNewsRecipe
import json
from datetime import datetime

class Rue89StrasbourgRecipe(BasicNewsRecipe):
    title = "Rue89 Strasbourg"
    __author__ = "Yannick Heinrich"
    description = "Les nouvelles de Rue89Strasbourg"
    no_stylesheets = True
    remove_tags_before = dict(name="main")
    remove_tags_after = dict(name="main")
    timefmt = '[%a, %d %b, %Y]'

    remove_tags = [
        dict(name="div", class_="hidden"),
        dict(name="div", attrs={'class': ['group', 'hidden']}),
        dict(name="div", class_="print:hidden"),
        # Author avatar and label
        dict(name="div", class_="overflow-hidden"),
        dict(name="strong", class_="block font-semibold mb-4 text-gray-700"),
        dict(name="a", class_="not-prose"),
        dict(name="div", class_="vt-post-breadcrumb"),
        dict(name="div", class_="bg-warning"),
        dict(name="div", class_="not-prose mb-8 md:mb-6"),
        dict(name="div", class_="wp-block-group md:flex-1 is-content-justification-right is-nowrap is-layout-flex wp-block-group-is-layout-flex"),
        dict(name="a", class_="group flex items-start justify-between leading-6 p-6 transition-colors duration-fast hover:bg-gray-200")
    ]

    # Login
    needs_subscription = "optional"

    def parse_index(self):
        # We get the current month
        current_month = datetime.now().month
        current_year = datetime.now().year
        soup  = self.index_to_soup(f'https://www.rue89strasbourg.com/date/{current_year}/{current_month}')
        articles = []
        for article in soup.findAll('article'):
            # We first find the date link
            article_date_tag = article.find('div', class_="mb-2 text-gray-600 text-sm")   
            article_date_raw = article_date_tag['title']
            article_date_py = datetime.strptime(article_date_raw,"le %d/%m/%Y à %Hh%M").date()
            article_date = article_date_py.strftime("%d/%m/%Y %H:%M")
            # Then the url is the link within the parent of this tag
            article_url = article_date_tag.parent['href']    
            article_title = self.tag_to_string(article.h2)
            article_description = self.tag_to_string(article.findAll('p')[1])
            fetched = dict(title=article_title, url=article_url, date=article_date, description=article_description, content="")            
            articles.append(fetched)
        return [('Derniers articles du mois', articles)]

    def get_browser(self):
        # We get the browser
        br = BasicNewsRecipe.get_browser(self)
        if self.username is not None and self.password is not None:
            # Retrieve the version
            response = br.open("https://www.rue89strasbourg.com/user/connexion")
            soup = BeautifulSoup(response.read())
            version_script_tag_mangled = soup.find(id="cookie-dynamic-script-js")["src"]
            parsed_url = urlparse(version_script_tag_mangled)
            version = parse_qs(parsed_url.query)["ver"]

            # Retrieve the login nonce
            response = br.open(
                f"https://www.rue89strasbourg.com/?r89-api=dynamic-script&ver={version}"
            )
            nonce_one_text = response.read().decode('utf-8')
            key='"form_async_login":"'
            index_find = nonce_one_text.find('"form_async_login":"')
            remaining = nonce_one_text[index_find + len(key):]
            next_opening = remaining.find('"')
            form_async_token = remaining[:next_opening]

            # Now login properly to the webpage  
            body = json.dumps({"email": self.username,"password": self.password, "remember-me":True, "tempcode": "", "redirect": "", "": False}).encode('utf-8')  

            login_request = mechanize.Request(
                f"https://www.rue89strasbourg.com/?r89-api=form_async_login&_wpnonce={form_async_token}",
                headers={'Referer': 'https://www.rue89strasbourg.com/user/connexion', 'Content-Type': ' application/json'},
                method="POST",
                data=body
                )
            response = br.open(login_request)
            br.open('https://www.rue89strasbourg.com/user/subscription')        
        return br


